#!/bin/sh
# Example per-worktree setup hook for agent-worktree-helpers.
#
# HOW TO USE
#   cp examples/worktree-setup /path/to/your/repo/.worktree-setup
#   chmod +x /path/to/your/repo/.worktree-setup
#   # edit it for your stack (delete what you do not need)
#
# wt / wtco / wtpr then run this inside each fresh worktree. The current
# directory is the new worktree; $1 (also $WT_SOURCE) is the checkout you ran
# the command from, so you can copy gitignored files out of it.
#
# Skip it for a one-off:  WT_NO_SETUP=1 wt my-task
set -eu

source_checkout=${1:-}

# 1) Copy gitignored runtime files the new worktree does not have yet.
#    A fresh worktree only contains tracked files, so .env (etc.) is missing.
for f in .env .env.local; do
  if [ -n "$source_checkout" ] && [ -f "$source_checkout/$f" ] && [ ! -f "$f" ]; then
    cp "$source_checkout/$f" "$f"
    echo "worktree-setup: copied $f"
  fi
done

# 2) Install dependencies. A Python virtualenv or node_modules cannot be shared
#    between worktrees (absolute paths + native binaries), so install fresh
#    here. Both are usually fast because the package managers share a global
#    cache across worktrees. Uncomment what applies:

# Python (uv):
# uv sync

# Python (pip + venv):
# python -m venv .venv && . .venv/bin/activate && pip install -e .

# Node (npm) — often only needed when you will touch the frontend:
# npm ci

echo "worktree-setup: done"
